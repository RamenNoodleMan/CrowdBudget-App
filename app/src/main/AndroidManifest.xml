<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.CrowdBudget">

        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".auth.RegisterActivity" />
        <activity android:name=".MainActivity" />
        <activity android:name=".ui.ShoppingBasketActivity" />
        <activity android:name=".ui.AddProductActivity" />
        <activity android:name=".ui.PriceContributionActivity" />
        <activity android:name=".ui.PreviousListsActivity" />

    </application>

</manifest>